data/surfaces/

# Optional: keep raw sample PDB files out of Git by default.
# Remove this line if you explicitly want to version a tiny demo input.
data/*.pdb

# Model weights are usually stored in a model registry or release artifact.
*.pt
*.pth
*.ckpt

# Keep only the Linux binary needed by Docker/CI.
utils/EDTSurf
utils/EDTSurf.exe

# Docker local files
docker-compose.override.yml
